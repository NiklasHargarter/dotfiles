# Ghostty config. Ported from the old alacritty setup.
# List builtin themes: `ghostty +list-themes`   Reload: cmd+shift+,

theme = TokyoNight

font-family = MesloLGS NF
font-size = 14

window-padding-x = 12
window-padding-y = 12
window-padding-balance = true

background-opacity = 0.98
background-blur-radius = 20

cursor-style = bar
cursor-style-blink = true
mouse-hide-while-typing = true

copy-on-select = clipboard

# Shift+Enter → ESC + CR (some TUIs / Claude Code use this for newline)
keybind = shift+enter=text:\x1b\r

# SSH: remote servers lack the xterm-ghostty terminfo (breaks keys/colors/clear
# + zellij). Ghostty's shell integration fixes it automatically:
#   ssh-terminfo — installs Ghostty's terminfo on the remote (full features)
#   ssh-env      — falls back to TERM=xterm-256color when it can't
# (cursor,title are the defaults — re-listed since this replaces the set.)
shell-integration-features = cursor,title,ssh-env,ssh-terminfo

